rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
         request.auth.token.email == 'kamaalabdirashiidadan@gmail.com'); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Complaint Validation ---
    function isValidComplaint(data) {
      return data.keys().hasAll(['tripleName', 'phone', 'category', 'complaint', 'status', 'createdAt']) &&
             data.keys().size() >= 6 &&
             data.tripleName is string && data.tripleName.size() <= 200 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.category in ['Barakicin', 'Cadaalad Daro', 'Shaqo Laga Dhacay', 'Dhul Dhaxal ah'] &&
             data.complaint is string && data.complaint.size() <= 5000 &&
             data.status in ['pending', 'reviewed', 'resolved'] &&
             data.createdAt == request.time &&
             (data.fullName == null || (data.fullName is string && data.fullName.size() <= 200)) &&
             (data.tribe == null || (data.tribe is string && data.tribe.size() <= 100)) &&
             (data.fileUrl == null || (data.fileUrl is string && data.fileUrl.size() <= 1000));
    }

    match /complaints/{complaintId} {
      allow create: if isValidId(complaintId) && isValidComplaint(incoming()) && 
                    incoming().status == 'pending';
      
      allow read: if isAdmin();
      
      allow update: if isAdmin() && 
                    isValidComplaint(incoming()) &&
                    (
                      // Admin can update status
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                      incoming().updatedAt == request.time
                    );
      
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
  }
}
